{
  "name": "bestvina-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "prerender": "bun prerender.ts",
    "generate": "bun run prerender && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "deploy-test": "wrangler pages deploy .output/public --project-name bestvina-test",
    "publish-test": "bun run generate && bun run deploy-test"
  },
  "dependencies": {
    "@nuxt/content": "^3.10.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/hints": "1.0.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/ui": "^4.3.0",
    "@types/node": "^25.0.3",
    "@vueuse/core": "^14.1.0",
    "eslint": "^10.0.0",
    "image-size": "^2.0.2",
    "nuxt": "^4.4.2",
    "nuxt-studio": "^1.0.0-beta.3",
    "typescript": "^6.0.2",
    "vue": "^3.5.26",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.15",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.91",
    "@iconify-json/material-symbols": "^1.2.50",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/proicons": "^1.2.18",
    "@iconify-json/simple-icons": "^1.2.71",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@playwright/test": "^1.58.2",
    "@vue/test-utils": "^2.4.6",
    "wrangler": "^4.66.0"
  }
}
